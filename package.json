{
	"name": "n8n-nodes-resourceplanner",
	"version": "0.1.0",
	"description": "n8n community node for Resource Planner projects, resources, and assignments.",
	"license": "MIT",
	"homepage": "https://resourceplanner.io",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"resourceplanner",
		"resource-planning",
		"project-management"
	],
	"author": {
		"name": "Adam Ilcisak",
		"email": "ilcisak@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ikisaka/n8n-nodes-resourceplanner.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/ResourceplannerApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Resourceplanner/Resourceplanner.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
